{
  "Name": "jmi-ingest-10min",
  "GroupName": "default",
  "ScheduleExpression": "rate(24 hours)",
  "FlexibleTimeWindow": {
    "Mode": "OFF"
  },
  "Target": {
    "Arn": "arn:aws:lambda:ap-south-1:470441577506:function:jmi-ingest-live",
    "RoleArn": "arn:aws:iam::470441577506:role/jmi-eventbridge-invoke-lambda-role",
    "Input": "{\"trigger\":\"eventbridge\",\"source\":\"schedule\"}"
  },
  "State": "ENABLED",
  "Description": "JMI pipeline (ingest→silver→gold) every 24 hours via EventBridge Scheduler"
}
